# Copy selected nonsecret values to a local .env; never commit credentials.
APP_PACKAGE_NAME=com.example.app
PLAY_STORE_TRACK=internal
PLAY_STORE_VERSION_TRACKS=internal,alpha,beta,production
PLAY_STORE_RELEASE_STATUS=completed
# PLAY_STORE_ROLLOUT=0.2
# VERSION_NAME=1.2.3
# VERSION_CODE=123
# FLUTTER_FLAVOR=production
RELEASE_DART_TARGET=lib/main.dart
RUN_FLUTTER_ANALYZE=true
RUN_FLUTTER_TESTS=false
RUN_BUILD_RUNNER=auto
DISTRIBUTION_TARGET=play-store
ENABLE_FIREBASE_APP_DISTRIBUTION=false
# CONFIRM_DUAL_DELIVERY=false
FIREBASE_ANDROID_ARTIFACT_TYPE=AAB
# CONFIRM_FIREBASE_AAB_PLAY_LINKED=true
# CONFIRM_FIREBASE_PACKAGE_MATCH=true
# CONFIRM_PRODUCTION_DEPLOY=true
# CONFIRM_PLAY_RELEASE_POLICY=false
# Unknown-outcome retries require a fresh run and the complete exact tuple.
# RETRY_UNKNOWN_UPLOAD=false
# CONFIRM_UPLOAD_RECONCILED=false
# RECONCILED_VERSION_NAME=
# RECONCILED_VERSION_CODE=
# RECONCILED_ARTIFACT_SHA256=
# RECONCILED_DESTINATIONS=
# RECONCILED_PROVIDER_STATE=
# FIREBASE_RELEASE_NOTES=Reviewed release notes
# RELEASE_RESULT_PATH=/absolute/nonsecret/release-result.json
# SLACK_NOTIFY_SUCCESS=true
# SLACK_NOTIFY_FAILURE=true
# CONFIRM_SLACK_NOTIFICATION=false
# SLACK_NOTIFICATION_OWNER=fastlane

# Secret-bearing inputs are names only; provide values through your shell or CI.
# ANDROID_KEYSTORE_PATH=/absolute/path/upload.jks
# ANDROID_KEYSTORE_BASE64=
# ANDROID_KEYSTORE_PASSWORD=
# ANDROID_KEY_ALIAS=
# ANDROID_KEY_PASSWORD=
# GOOGLE_PLAY_SERVICE_ACCOUNT_JSON_PATH=/absolute/path/play-service-account.json
# GOOGLE_PLAY_SERVICE_ACCOUNT_JSON_BASE64=
# FIREBASE_APP_ID=
# FIREBASE_SERVICE_ACCOUNT_JSON_PATH=/absolute/path/firebase-service-account.json
# FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=
# FIREBASE_TESTERS=
# FIREBASE_TESTER_GROUPS=
# SLACK_WEBHOOK_URL=
